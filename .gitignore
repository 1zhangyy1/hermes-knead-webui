# Local reference checkouts. Production source lives in apps/, packages/,
# products/, docs/, and scripts/.
vendor/

# Local dependency/runtime output inside production app and experiments.
apps/**/.venv/
apps/**/.venv*/
apps/**/node_modules/
apps/**/.pytest_cache/
apps/**/__pycache__/
experiments/**/node_modules/
experiments/**/dist/
experiments/**/.vite/
experiments/**/.next/
experiments/**/build/

# Generated local build/runtime outputs
apps/**/dist/
# `products/` is source-only for curated built-in examples. Runtime
# user-created products belong in `.hermes-home/webui/products/`.
products/*
!products/README.md
!products/catalog.json
!products/product-catalog.schema.json
!products/product.schema.json
!products/general/
!products/general/**
!products/ppt-designer/
!products/ppt-designer/**
!products/ai-otome/
!products/ai-otome/**
products/**/versions/
experiments/generated/

# Product runtime junk: generated decks, secrets, venvs, caches (engine code itself IS tracked)
products/**/outputs/
products/**/.env
products/**/.knead-published.json
products/**/.venv/
products/**/__pycache__/
products/**/*.lock
products/**/*.pptx

# Generated demo/test artifacts from running products (not source)
products/**/hermes_intro.*

# Runtime per-deck canvas state (agent-written, not source)
products/**/state.json
