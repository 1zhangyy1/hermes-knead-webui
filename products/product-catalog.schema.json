{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knead.dev/schemas/product-catalog.schema.json",
  "title": "Knead AI Product Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "builtins"],
  "properties": {
    "$schema": {
      "const": "https://knead.dev/schemas/product-catalog.schema.json"
    },
    "builtins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "uniqueItems": true
    }
  }
}
