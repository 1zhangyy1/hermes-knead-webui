# Knead local development configuration
#
# Copy to `.env` at the repository root:
#
#   cp .env.example .env
#
# `pnpm dev` reads this file and keeps runtime state inside this checkout by
# default. Do not commit your real `.env`.

# Local state and Hermes runtime home.
HERMES_HOME=.hermes-home
HERMES_WEBUI_STATE_DIR=.hermes-home/webui

# Web UI bind address.
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=8788

# Source boundaries.
KNEAD_PROJECT_ROOT=.
# KNEAD_BUILTIN_PRODUCTS_DIR=products
# KNEAD_PRODUCTS_DIR=.hermes-home/webui/products

# Optional: force a Python executable. Leave blank to use the project-local
# environment prepared by `pnpm setup:local`.
# HERMES_WEBUI_PYTHON=

# LLM provider credentials.
# At least one provider must be configured before the agent can answer.
# OpenRouter is the simplest default path for this project-local setup.
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Optional tool/service keys.
# FAL_KEY is used by the PPT Designer image workflow.
# FAL_KEY=

# Optional local Hermes API smoke defaults.
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
HERMES_DASHBOARD_HOST=127.0.0.1
HERMES_DASHBOARD_PORT=9119
